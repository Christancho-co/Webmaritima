generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/maritima_boats_website/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model ContactForm {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  subject         String?
  preferredModel  String?
  message         String   @db.Text
  status          String   @default("new")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([createdAt])
}

model QuoteRequest {
  id              String   @id @default(cuid())
  fullName        String
  email           String
  phone           String?
  companyName     String?
  boatModel       String
  category        String
  projectDetails  String   @db.Text
  budget          String?
  timeline        String?
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([boatModel])
}
